{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "lcars-ngx": {
      "projectType": "library",
      "root": "",
      "sourceRoot": "src",
      "prefix": "lcars",
      "architect": {
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "lcars-ngx:build-storybook",
            "compodoc": false,
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "lcars-ngx:build-storybook",
            "compodoc": false,
            "outputDir": "storybook-static"
          }
        }
      }
    }
  }
}
